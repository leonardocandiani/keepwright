#!/usr/bin/env bash
# setup-oauth-secret.sh — seta CLAUDE_CODE_OAUTH_TOKEN no GitHub Secrets
# de forma determinística, evitando malformação por pipe/encoding.
#
# Catalisador: L-007 (secret oauth malformado por cadeia de pipes).
#
# O bug: cadeias `printf "$T" | tr -d ... | gh secret set --body -` podem
# introduzir caracteres invisíveis (newline, BOM, surrogates) que tornam
# o bearer header malformado. Resultado: API Anthropic responde HTTP 200
# pro curl direto (tolerante) mas o SDK do `claude-code-action` rejeita
# com 401 Invalid bearer token (estrito). Mesma chave, comportamentos
# diferentes.
#
# Solução canônica: ler token do Keychain pra arquivo binário, validar
# tamanho byte-exato (108 bytes pra sk-ant-oat01), setar via stdin
# redirect (`< /path/to/file.bin`) sem nenhuma transformação. Apagar
# arquivo no fim.
#
# Uso:
#   bash scripts/setup-oauth-secret.sh <owner>/<repo>
#
# Pré-requisitos:
#   - gh CLI autenticado (`gh auth status`)
#   - macOS com `claude` Code logado no Keychain (entry "Claude Code-credentials")
#     OU variável de ambiente CLAUDE_CODE_OAUTH_TOKEN setada pré-execução
#   - jq instalado

set -euo pipefail

REPO="${1:-}"
if [ -z "$REPO" ]; then
  echo "uso: $0 <owner>/<repo>" >&2
  exit 1
fi

# Verificar gh autenticado
if ! gh auth status >/dev/null 2>&1; then
  echo "❌ gh CLI não autenticado. Rode: gh auth login" >&2
  exit 1
fi

# Verificar repo acessível
if ! gh repo view "$REPO" >/dev/null 2>&1; then
  echo "❌ Repo $REPO não acessível com sua auth." >&2
  exit 1
fi

# Arquivo temporário com permissão restrita
TOKEN_FILE=$(mktemp -t oauth-token.XXXXXX)
trap 'rm -f "$TOKEN_FILE"' EXIT INT TERM
chmod 600 "$TOKEN_FILE"

# Extrair token: prioridade Keychain (macOS), fallback env var
if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
  printf '%s' "$CLAUDE_CODE_OAUTH_TOKEN" > "$TOKEN_FILE"
  echo "📦 Origem: variável de ambiente CLAUDE_CODE_OAUTH_TOKEN."
elif command -v security >/dev/null 2>&1; then
  # macOS Keychain — entry padrão do `claude` Code CLI
  RAW=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)
  if [ -z "$RAW" ]; then
    echo "❌ Keychain não tem entry 'Claude Code-credentials'." >&2
    echo "   Rode 'claude setup-token' primeiro (sessão isolada)." >&2
    exit 1
  fi
  TOKEN=$(echo "$RAW" | jq -r '.claudeAiOauth.accessToken // empty')
  if [ -z "$TOKEN" ]; then
    echo "❌ Entry Keychain existe mas sem .claudeAiOauth.accessToken." >&2
    exit 1
  fi
  printf '%s' "$TOKEN" > "$TOKEN_FILE"
  unset TOKEN RAW
  echo "📦 Origem: Keychain macOS (entry 'Claude Code-credentials')."
else
  echo "❌ Nem CLAUDE_CODE_OAUTH_TOKEN no env, nem 'security' (macOS) disponível." >&2
  echo "   Setar via: export CLAUDE_CODE_OAUTH_TOKEN='sk-ant-oat01-...' e re-executar." >&2
  exit 1
fi

# Validar shape do token
BYTES=$(wc -c < "$TOKEN_FILE" | tr -d ' ')
PREFIX=$(head -c 12 "$TOKEN_FILE")

if [ "$PREFIX" != "sk-ant-oat01" ]; then
  echo "❌ Token não começa com 'sk-ant-oat01-' (prefixo OAuth do Claude Code)." >&2
  echo "   Prefixo encontrado: '$PREFIX'" >&2
  echo "   Talvez seja API key (sk-ant-api01-) — use ANTHROPIC_API_KEY em vez disso." >&2
  exit 1
fi

# Validar zero whitespace residual
LAST_CHAR=$(tail -c 1 "$TOKEN_FILE" | xxd -p)
case "$LAST_CHAR" in
  0a|0d|20|09)
    echo "❌ Token tem whitespace no final (hex=$LAST_CHAR). Possível malformação." >&2
    exit 1
    ;;
esac

echo "✅ Token validado: $BYTES bytes, prefixo OAuth, sem whitespace residual."

# Setar via stdin redirect (zero transformação)
gh secret set CLAUDE_CODE_OAUTH_TOKEN -R "$REPO" < "$TOKEN_FILE"

echo "✅ CLAUDE_CODE_OAUTH_TOKEN setado em $REPO."
echo ""
echo "🔍 Verifique tamanho via diagnóstico no workflow:"
echo "   echo \"len=\${#CLAUDE_CODE_OAUTH_TOKEN}\"  # esperado: $BYTES"
echo ""
echo "🤖 Não esqueça de instalar o GitHub App Claude no repo:"
echo "   https://github.com/apps/claude/installations/new"
echo "   (sem o app instalado, App token exchange falha 401)"
