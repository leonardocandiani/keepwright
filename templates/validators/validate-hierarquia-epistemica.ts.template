#!/usr/bin/env bun
/**
 * validate-hierarquia-epistemica.ts
 *
 * Gate: detecta linguagem que sugere inversão hierárquica (P5 refutando P1)
 * em PR title/body/commits. Phrases como "ZERO bugs detectados", "código está
 * 100% correto", "hipótese sem evidência confirmou-se infundada" — quando
 * usadas sem evidência empírica cirúrgica, são tentativas de fechar
 * investigação prematuramente.
 *
 * Bypass legítimo: blockquote markdown `>` + evidência adjacente OU comment
 * inline `// hierarquia-epistemica: ignore <razão>` janela 3 linhas.
 *
 * Roda em commit-msg via lefthook + em PR auto-review via env vars
 * (PR_TITLE, PR_BODY, COMMIT_MESSAGES).
 */

const PATTERNS_RUINS = [
  /ZERO bugs (detectados|encontrados|identificados)/i,
  /padrão arquitetural está (100%|totalmente|completamente) correto/i,
  /briefing baseado em premissa empíricamente refutada/i,
  /hipótese sem evidência confirmou-se infundada/i,
  /bug não existe — talvez você esteja confundindo/i,
  /se você teve bug em produção, me passe sintoma/i,
];

function ignoreAdjacent(text: string, hitIdx: number): boolean {
  // Olha 3 linhas pra trás e 3 linhas pra frente; se tem comment de ignore OU
  // blockquote `>` adjacente com evidência (números, datas, paths), aceita.
  const lines = text.split("\n");
  const upToHit = text.substring(0, hitIdx).split("\n").length - 1;
  const start = Math.max(0, upToHit - 3);
  const end = Math.min(lines.length, upToHit + 4);
  const window = lines.slice(start, end).join("\n");

  if (/\/\/\s*hierarquia-epistemica:\s*ignore/.test(window)) return true;
  // blockquote markdown + evidência (paths, timestamps, SHAs, números)
  const hasBlockquote = />\s+/.test(window);
  const hasEvidence = /\b(\d{4}-\d{2}-\d{2}|[a-f0-9]{7,40}|\/[a-z][\w\-\/.]+\.(ts|tsx|js|md|sql))\b/.test(window);
  if (hasBlockquote && hasEvidence) return true;

  return false;
}

function scanText(text: string, source: string): string[] {
  const violations: string[] = [];
  for (const re of PATTERNS_RUINS) {
    const m = re.exec(text);
    if (!m) continue;
    if (ignoreAdjacent(text, m.index)) continue;
    violations.push(`[${source}] linha "${m[0]}" sem evidência cirúrgica adjacente`);
  }
  return violations;
}

// Inputs: env vars (CI) ou commit-msg file (lefthook)
const PR_TITLE = process.env.PR_TITLE || "";
const PR_BODY = process.env.PR_BODY || "";
const COMMIT_MESSAGES = process.env.COMMIT_MESSAGES || "";

let commitMsg = "";
if (process.argv[2]) {
  try {
    commitMsg = readFileSync(process.argv[2], "utf-8");
  } catch {}
}

const allText = [PR_TITLE, PR_BODY, COMMIT_MESSAGES, commitMsg].join("\n---\n");

if (!allText.trim()) {
  console.log("validate-hierarquia-epistemica: sem input (sem env vars nem arquivo), skip.");
  process.exit(0);
}

const violations = scanText(allText, "input");

if (violations.length > 0) {
  console.error("\x1b[31m❌ validate-hierarquia-epistemica: linguagem de inversão hierárquica detectada\x1b[0m");
  console.error("");
  console.error("P5 (auditoria abstrata) NUNCA refuta P1 (sintoma reportado). Padrões abaixo");
  console.error("sugerem fechamento prematuro de investigação sem evidência empírica:");
  console.error("");
  for (const v of violations) console.error(`   - ${v}`);
  console.error("");
  console.error("Bypass: blockquote `>` + evidência (path/SHA/timestamp) adjacente OU");
  console.error("comment `// hierarquia-epistemica: ignore <razão>` janela 3 linhas.");
  console.error("Ver `.claude/rules/03-hierarquia-epistemica.md`.");
  process.exit(1);
}

console.log("\x1b[32m✅ validate-hierarquia-epistemica: zero violações detectadas.\x1b[0m");
