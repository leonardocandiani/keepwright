#!/usr/bin/env bun
/**
 * validate-webhook-active.ts
 *
 * Gate L-001: se CLAUDE.md menciona "webhook GitHub" ou "deploy automático",
 * `gh api repos/<owner>/<repo>/hooks` precisa retornar pelo menos 1 webhook
 * ativo apontando pra um host documentado. Doc sem smoke E2E = doc sem prova.
 *
 * Skipado se `gh` não está autenticado (dev local sem token) — só falha em CI
 * onde GH_TOKEN está garantido.
 */

import { execSync } from "node:child_process";
import { existsSync, readFileSync } from "node:fs";

const CLAUDE_MD = "CLAUDE.md";

function fail(msg: string): never {
  console.error(`\x1b[31m❌ validate-webhook-active: ${msg}\x1b[0m`);
  process.exit(1);
}

function ok(msg: string): void {
  console.log(`\x1b[32m✅ validate-webhook-active: ${msg}\x1b[0m`);
}

if (!existsSync(CLAUDE_MD)) {
  console.log("validate-webhook-active: CLAUDE.md ausente, nada a checar.");
  process.exit(0);
}

const claudeMd = readFileSync(CLAUDE_MD, "utf-8");
const mencionaWebhook = /webhook (github|deploy)|deploy automático|deploy.*via webhook/i.test(claudeMd);

if (!mencionaWebhook) {
  console.log("validate-webhook-active: CLAUDE.md não menciona webhook/deploy automático, skip.");
  process.exit(0);
}

// Verifica se gh CLI tem auth
try {
  execSync("gh auth status", { stdio: "pipe" });
} catch {
  console.log("validate-webhook-active: gh CLI não autenticado, skip (dev local).");
  process.exit(0);
}

// Detecta owner/repo via git remote
let repoSlug: string;
try {
  const remoteUrl = execSync("git config --get remote.origin.url", { encoding: "utf-8" }).trim();
  const m = remoteUrl.match(/github\.com[:\/]([^\/]+\/[^\/.]+)/);
  if (!m) fail(`não consegui parsear repo do remote: ${remoteUrl}`);
  repoSlug = m[1].replace(/\.git$/, "");
} catch (err) {
  fail(`erro detectando repo: ${err}`);
}

// gh api repos/.../hooks — requer scope `admin:repo_hook`. Skip gracefully
// em CI default (GITHUB_TOKEN não tem esse scope) — só falha em ambiente
// com PAT (dev local ou self-hosted runner com PAT_HOOK env).
let hooks: Array<{ id: number; active: boolean; events: string[]; config: { url?: string } }>;
try {
  const raw = execSync(`gh api repos/${repoSlug}/hooks`, { encoding: "utf-8", stdio: ["pipe", "pipe", "pipe"] });
  hooks = JSON.parse(raw);
} catch (err: any) {
  const msg = String(err.stderr || err.message || err);
  if (msg.includes("403") || msg.includes("404") || msg.includes("Not Found") || msg.includes("Resource not accessible")) {
    console.log(`validate-webhook-active: gh api retornou 403/404 (scope admin:repo_hook ausente), skip gracefully em CI default.`);
    process.exit(0);
  }
  fail(`gh api falhou: ${msg}`);
}

const ativos = hooks.filter((h) => h.active && h.events.includes("push"));

if (ativos.length === 0) {
  fail(
    `${CLAUDE_MD} menciona webhook/deploy automático mas ZERO webhooks ativos em ${repoSlug}.\n` +
      `   Doc descritiva sem implementação validada (L-001).\n` +
      `   Configure via: gh api -X POST repos/${repoSlug}/hooks --input <(echo '{...}')`
  );
}

ok(`${ativos.length} webhook(s) ativo(s) com push event em ${repoSlug}:`);
for (const h of ativos) {
  console.log(`   - id=${h.id} url=${h.config.url || "?"} events=[${h.events.join(",")}]`);
}
