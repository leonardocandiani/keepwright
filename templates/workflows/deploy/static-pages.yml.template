name: Deploy (GitHub Pages)

# Stack: static site (build → HTML/CSS/JS). Publishes to GitHub Pages.
# Triggers post-merge on main. No secret required (uses native Pages).
#
# Prerequisite: Settings → Pages → Source = GitHub Actions (once, manual).
# Set BUILD_DIR to your build's output directory.

on:
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: true

env:
  BUILD_DIR: '{{BUILD_DIR}}'

jobs:
  build:
    name: Build
    runs-on: ubuntu-latest
    if: github.repository == '{{REPO}}'
    steps:
      - uses: actions/checkout@v5

      - uses: actions/setup-node@v4
        with: { node-version: lts/* }

      - run: npm ci
      - run: npm run build --if-present

      - uses: actions/configure-pages@v5
      - uses: actions/upload-pages-artifact@v3
        with:
          path: ${{ env.BUILD_DIR }}

  deploy:
    name: Deploy
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v4
